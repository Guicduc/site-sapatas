DATABASE_URL=
DATABASE_SSL=true
NEXT_PUBLIC_SITE_URL=https://www.baseforma.com.br
GOOGLE_SITE_VERIFICATION=
# Recuperacao de carrinho usa DATABASE_URL ou .local-data/cart-recovery.dev.json. Nao envia mensagens automaticamente.
CART_RECOVERY_RETENTION_DAYS=90

MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ENV=sandbox
MERCADO_PAGO_STATEMENT_DESCRIPTOR=BASEFORMA
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_PREFERENCE_TTL_MINUTES=120

ADMIN_ACCESS_TOKEN=
ADMIN_SESSION_SECRET=
ACCOUNT_SESSION_SECRET=
RESEND_API_KEY=
TRANSACTIONAL_EMAIL_FROM=Baseforma <pedidos@send.baseforma.com.br>
TRANSACTIONAL_EMAIL_REPLY_TO=atendimento@baseforma.com.br
ACCOUNT_EMAIL_FROM=Baseforma <conta@send.baseforma.com.br>

# Contratos operacionais atuais. Lancamento usa frete manual estimado via Correios.
# Para homologar cotacao Melhor Envio sem etiqueta automatica, use SHIPPING_PROVIDER=melhor_envio
# com MELHOR_ENVIO_ENV=sandbox, token e CEP de origem; a postagem continua manual.
SHIPPING_PROVIDER=manual
SHIPPING_ORIGIN_POSTAL_CODE=
SHIPPING_PRODUCT_PADDING_CM=0.5
SHIPPING_PACKAGING_WEIGHT_GRAMS=20
SHIPPING_MIN_PRODUCT_DIMENSION_CM=1
SHIPPING_MIN_PRODUCT_WEIGHT_KG=0.01
MELHOR_ENVIO_ENV=sandbox
MELHOR_ENVIO_ACCESS_TOKEN=
MELHOR_ENVIO_USER_AGENT=Baseforma (tecnico@baseforma.com.br)
MELHOR_ENVIO_SERVICE_IDS=
MELHOR_ENVIO_PREFERRED_SERVICE_IDS=
INVOICE_PROVIDER=mercado_pago
# Endpoint fiscal Mercado Pago deve ser preenchido quando liberado para a conta.
MERCADO_PAGO_INVOICE_API_URL=
MERCADO_PAGO_INVOICE_API_TOKEN=
PRODUCTION_DAILY_UNIT_CAPACITY=120

ORCA_SLICER_PATH=Produtos/tools/OrcaSlicer_Windows_V2.3.1_portable/orca-slicer.exe
ORCA_SLICER_OUTPUT_DIR=Produtos/slicer-output-current
ORCA_DATASET_PATH=Produtos/datasets/slicer_pricing_dataset.csv
ORCA_SLICER_PROFILES_DIR=
ORCA_SLICER_PROFILE_ID=p2s-0.4-tpu-220c-layer-0.2-infill-8-walls-2-shells-3
ORCA_PRINTER_ID=bambu-p2s
ORCA_MATERIAL_ID=tpu
ORCA_NOZZLE_TEMP_C=220
ORCA_BED_TEMP_C=35
ORCA_SLICER_CONCURRENCY=4
ORCA_SLICER_LOAD_SETTINGS=Produtos/orca-cli-profiles/p2s-04-tpu-machine-cli-estimate.json;Produtos/orca-cli-profiles/p2s-020-process.json
ORCA_SLICER_LOAD_FILAMENTS=Produtos/orca-cli-profiles/generic-tpu-220.json
ORCA_SLICER_EXTRA_ARGS=--allow-newer-file
ORCA_SLICER_TIMEOUT_MS=180000

PRICING_REFERENCE_NOTES=TPU 170/kg; energia SP efetiva 0.95/kWh; P2S 200W medio; custo publico deve vir somente de material_grams e print_minutes preenchidos em Produtos/datasets/slicer_pricing_dataset.csv
